pkgname=ipcode
pkgver=0.2.0
pkgrel=1
pkgdesc="IPcode interpreter and toolchain"
arch=('x86_64')
url="https://github.com/m4rcel-lol/ipcode"
license=('MIT')
depends=('glibc')
makedepends=('cargo')
source=("${pkgname}-src.tar.gz")
# Replaced in CI with the SHA256 of the generated source archive before makepkg runs.
sha256sums=('SKIP')

build() {
    cd "$srcdir"
    cargo build --release --locked
}

package() {
    cd "$srcdir"
    install -Dm755 target/release/ipcode "$pkgdir/usr/bin/ipcode"
    install -Dm644 README.md "$pkgdir/usr/share/doc/ipcode/README.md"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/ipcode/LICENSE"
}
