# IPcode Standard Library — Math utilities
#
# abs(R0) — compute absolute value of R0, result in R0
# Usage: set R0, then CALL to the abs label line number.
#
# Line 1: ABS routine
#   4.3.0.0   LT R0, R_zero  — check if R0 < 0 (compare with R14 which should be 0)
#   5.2.0.4   JF 4           — if not negative, jump past negation
#   2.7.0.0   NEG R0, R0     — R0 = -R0
#   7.1.0.0   RET
#
# max(R0, R1) — result in R0
# min(R0, R1) — result in R0

# ABS: assumes R14 = 0 (caller responsibility)
# 1: check sign
4.3.0.14     # LT R0, R14   (FLAGS = R0 < 0)
5.2.0.4      # JF 4         (skip if not negative)
2.7.0.0      # NEG R0, R0   (R0 = -R0)
7.1.0.0      # RET

# MAX(R0, R1): returns larger value in R0
4.4.0.1      # GT R0, R1
5.1.0.8      # JT 8         (R0 > R1, keep R0)
1.3.0.1      # MOV R0, R1   (R0 = R1)
7.1.0.0      # RET

# MIN(R0, R1): returns smaller value in R0
4.3.0.1      # LT R0, R1
5.1.0.12     # JT 12        (R0 < R1, keep R0)
1.3.0.1      # MOV R0, R1   (R0 = R1)
7.1.0.0      # RET
